/*
 * mlp_weights.h — MLP weights extracted from binary_mlp_(dl_baseline).joblib
 *
 * Architecture : 13 → ReLU(64) → ReLU(32) → sigmoid(1)
 * Input        : 13 unified network features (log1p transformed, see section 3.10)
 * F1           : 0.9816  |  ROC-AUC : 0.9843  (TON_IoT binary, 38095 test samples)
 * Dataset      : TON_IoT train_test_network.csv
 *
 * Feature order (index 0-12):
 *   0: bytes_total      log1p(src_bytes + dst_bytes)
 *   1: bytes_src        log1p(src_bytes)
 *   2: bytes_dst        log1p(dst_bytes)
 *   3: pkts_total       log1p(src_pkts + dst_pkts)
 *   4: byte_asymmetry   (src_bytes - dst_bytes) / (src_bytes + dst_bytes + 1)
 *   5: pkt_asymmetry    (src_pkts  - dst_pkts)  / (src_pkts  + dst_pkts  + 1)
 *   6: payload_mean_fwd log1p(src_bytes / (src_pkts + 1))
 *   7: payload_mean_bwd log1p(dst_bytes / (dst_pkts + 1))
 *   8: flow_duration    log1p(duration)
 *   9: flow_rate        log1p((src_pkts+dst_pkts)/(duration+1e-6))
 *  10: proto_other      1 if proto not in {tcp,udp,icmp}
 *  11: service_other    1 if service is '-' or unknown
 *  12: conn_state_other 1 if conn_state not in {SF,S0,REJ,RSTO,RSTR}
 *
 * Classes: 0 = normal, 1 = attack  (output = P(attack))
 * Threshold: 0.5
 */

